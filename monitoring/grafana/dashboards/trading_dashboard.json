      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT (count(*) filter (where net_pnl > 0) * 100.0 / count(*)) as win_rate FROM auto_trade_executions WHERE status = 'CLOSED'",
          "refId": "A"
        }
      ],
      "title": "Win Rate",
      "type": "stat"
    },
