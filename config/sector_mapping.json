  "market_cap_estimates": {
    "description": "Estimated market capitalization categories for size-based analysis",
    "large_cap": {
      "threshold": 100000,
      "description": "Market cap > ₹1 lakh crore",
      "examples": ["RELIANCE", "TCS", "HDFCBANK", "INFY", "ICICIBANK"]
    },
    "mid_cap": {
      "threshold": 5000,
      "description": "Market cap between ₹5000 - ₹1 lakh crore",
      "examples": ["GODREJCP", "MPHASIS", "JUBLFOOD", "TORNTPHARM"]
    },
    "small_cap": {
      "threshold": 0,
      "description": "Market cap < ₹5000 crore",
      "examples": ["YESBANK", "IDEA", "RBLBANK"]
    }
  },
  "sector_performance_colors": {
    "description": "Color scheme for performance-based visualization",
    "strong_positive": "#004d00",
    "positive": "#008000",
    "light_positive": "#90EE90",
    "neutral": "#808080",
    "light_negative": "#FFB6C1",
    "negative": "#FF0000",
    "strong_negative": "#8B0000"
  },
  "api_mappings": {
    "description": "API endpoint mappings for frontend integration",
    "endpoints": {
      "get_all_sectors": "/api/sectors",
      "get_sector_details": "/api/sectors/{sector_key}",
      "get_sector_stocks": "/api/analytics/sectors/{sector_key}/stocks",
      "bloomberg_heatmap": "/api/heatmap/bloomberg-style",
      "enhanced_heatmap": "/api/analytics/heatmap/enhanced",
      "treemap_data": "/api/analytics/treemap",
      "sector_performance": "/api/analytics/sector-performance",
      "enhanced_dashboard": "/api/analytics/enhanced-dashboard",
      "sector_summary": "/api/analytics/sector-summary"
    },
    "websocket_endpoints": {
      "market_data": "/ws/market-data",
      "dashboard": "/api/v1/ws/dashboard",
      "analytics": "/ws/market-analytics"
    }
  },
  "data_validation": {
    "description": "Data validation rules and constraints",
    "required_fields": ["symbol", "name", "lot_size"],
    "optional_fields": ["isin", "underlying"],
    "symbol_format": "UPPERCASE_ALPHANUMERIC",
    "lot_size_range": {
      "min": 5,
      "max": 50000
    },
    "sector_key_format": "UPPERCASE_UNDERSCORE"
  }
