# Environment Configuration Template
# Copy this file to .env and replace all placeholder values with actual credentials
# WARNING: NEVER commit .env file with real credentials to version control

BROKER_API_KEY=REPLACE_WITH_ACTUAL_API_KEY

# PostgreSQL connection settings
DATABASE_URL=postgresql://postgres:password@localhost:5432/tradingapp

# Broker API settings
ZERODHA_API_KEY=REPLACE_WITH_ACTUAL_ZERODHA_API_KEY
ZERODHA_API_SECRET=REPLACE_WITH_ACTUAL_ZERODHA_API_SECRET
UPSTOX_API_KEY=REPLACE_WITH_ACTUAL_UPSTOX_API_KEY
UPSTOX_API_SECRET=REPLACE_WITH_ACTUAL_UPSTOX_API_SECRET

# Yahoo Finance API
YAHOO_FINANCE_API_KEY=REPLACE_WITH_ACTUAL_YAHOO_API_KEY

# Broker Selection (upstox/zerodha)
BROKER_NAME=upstox

# Upstox Configuration
UPSTOX_REDIRECT_URI=http://localhost:8000/api/broker/upstox/callback
UPSTOX_MOBILE=REPLACE_WITH_ACTUAL_MOBILE
UPSTOX_PIN=REPLACE_WITH_ACTUAL_PIN
UPSTOX_TOTP_KEY=REPLACE_WITH_ACTUAL_TOTP_KEY
UPSTOX_HEADLESS=false

# Zerodha Configuration
ZERODHA_REDIRECT_URI=http://localhost:8000/api/broker/callback/zerodha

# Fyers Configuration
FYERS_REDIRECT_URI=http://localhost:8000/api/broker/upstox/callback

# Active Broker
ACTIVE_BROKER=upstox

# Trading Parameters
TRADING_SYMBOL=RELIANCE
TRADING_QUANTITY=1
RISK_PER_TRADE=0.01

# Options Trading Configuration
OPTIONS_INDEX=NIFTY
OPTION_TYPE=CE
STRIKE_OFFSET=0
EXPIRY_SELECTION=WEEKLY
LOT_SIZE=50
MAX_LOTS=2

# Options Trading Strategy
OPTIONS_STRATEGY=DIRECTIONAL
STOP_LOSS_PERCENTAGE=20
TARGET_PERCENTAGE=40

# JWT Configuration - MUST be strong random values
JWT_SECRET=GENERATE_STRONG_RANDOM_SECRET_KEY_32_CHARS_MIN
REFRESH_SECRET=GENERATE_STRONG_RANDOM_REFRESH_SECRET_KEY

# Twilio Configuration
TWILIO_ACCOUNT_SID=REPLACE_WITH_ACTUAL_TWILIO_SID
TWILIO_AUTH_TOKEN=REPLACE_WITH_ACTUAL_TWILIO_TOKEN
TWILIO_PHONE_NUMBER=REPLACE_WITH_ACTUAL_PHONE_NUMBER

# Angel One Configuration
ANGEL_CLIENT_ID=REPLACE_WITH_ACTUAL_ANGEL_CLIENT_ID
ANGEL_API_KEY=REPLACE_WITH_ACTUAL_ANGEL_API_KEY
ANGEL_API_SECRET=REPLACE_WITH_ACTUAL_ANGEL_API_SECRET
ANGEL_REDIRECT_URI=REPLACE_WITH_ACTUAL_ANGEL_REDIRECT_URI
ANGEL_USERNAME=REPLACE_WITH_ACTUAL_ANGEL_USERNAME
ANGEL_PASSWORD=REPLACE_WITH_ACTUAL_ANGEL_PASSWORD

# Service Feature Flags
ENABLE_MARKET_DATA=true
ENABLE_UI_WEBSOCKET=true  
ENABLE_INSTRUMENT_SERVICE=true

# Performance Settings
MAX_WEBSOCKET_INSTRUMENTS=1500
MAX_UI_CLIENTS=100
MARKET_DATA_CACHE_TTL=300
MARKET_DATA_RETRY_ATTEMPTS=5
MARKET_DATA_RETRY_DELAY=5
CLIENT_PING_INTERVAL=30
CLIENT_TIMEOUT=300
BROADCAST_BATCH_SIZE=100
BROADCAST_INTERVAL_MS=100
INSTRUMENTS_REFRESH_INTERVAL=21600
INSTRUMENTS_CACHE_TTL=86400
MAX_TRADING_STOCKS=200
OPTION_STRIKE_RANGE=40

# Development Settings (set to false in production)
ENABLE_TEST_DATA=false
ENABLE_MOCK_UPSTOX=false
ENABLE_WEBSOCKET_DEBUG=false
ENABLE_MARKET_DATA_DEBUG=false

# Admin Configuration
ADMIN_EMAIL=REPLACE_WITH_ACTUAL_ADMIN_EMAIL