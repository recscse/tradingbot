# PostgreSQL connection settings
DATABASE_URL=postgresql://postgres:root@localhost:5432/tradingapp
# Broker API settings
ZERODHA_API_KEY=your_zerodha_api_key
ZERODHA_API_SECRET=your_zerodha_api_secret
UPSTOX_API_KEY=your_api_key_here
UPSTOX_API_SECRET=your_api_secret_here

# Yahoo Finance API
YAHOO_FINANCE_API_KEY=**********************

# Broker Selection (upstox/zerodha)
BROKER_NAME=upstox

# Upstox Configuration
UPSTOX_API_KEY=your_upstox_api_key
UPSTOX_API_SECRET=your_upstox_api_secret
UPSTOX_REDIRECT_URI=http://localhost:8000/api/broker/upstox/callback

# Zerodha Configuration
ZERODHA_API_KEY=your_zerodha_api_key
ZERODHA_API_SECRET=your_zerodha_api_secret
ZERODHA_REDIRECT_URI=http://localhost:8000/api/broker/callback/zerodha


# Fyers Configuration
FYERS_REDIRECT_URI=http://localhost:8000/api/broker/upstox/callback

# Active Broker
ACTIVE_BROKER=upstox

# Trading Parameters
TRADING_SYMBOL=RELIANCE
TRADING_QUANTITY=1
RISK_PER_TRADE=0.01

# Options Trading Configuration
OPTIONS_INDEX=NIFTY
OPTION_TYPE=CE
STRIKE_OFFSET=0
EXPIRY_SELECTION=WEEKLY
LOT_SIZE=50
MAX_LOTS=2
RISK_PER_TRADE=0.01

# Options Trading Strategy
OPTIONS_STRATEGY=DIRECTIONAL  # DIRECTIONAL/STRANGLE/STRADDLE
STOP_LOSS_PERCENTAGE=20
TARGET_PERCENTAGE=40
JWT_SECRET=your-access-secret-key
REFRESH_SECRET=your-refresh-secret-key

TWILIO_ACCOUNT_SID=*******************************
TWILIO_AUTH_TOKEN=*******************************
TWILIO_PHONE_NUMBER=***********



ANGEL_CLIENT_ID=******** 
ANGEL_API_KEY=******** 
ANGEL_API_SECRET=****************
ANGEL_REDIRECT_URI=***************
ANGEL_USERNAME=*****
ANGEL_PASSWORD=****


# === ADD THESE TO YOUR EXISTING .env FILE ===

# Service Separation Feature Flags
ENABLE_MARKET_DATA=true
ENABLE_UI_WEBSOCKET=true  
ENABLE_INSTRUMENT_SERVICE=true

# Upstox WebSocket Limits
MAX_WEBSOCKET_INSTRUMENTS=1500
MAX_UI_CLIENTS=100

# Market Data Settings
MARKET_DATA_CACHE_TTL=300
MARKET_DATA_RETRY_ATTEMPTS=5
MARKET_DATA_RETRY_DELAY=5

# UI WebSocket Settings
CLIENT_PING_INTERVAL=30
CLIENT_TIMEOUT=300
BROADCAST_BATCH_SIZE=100
BROADCAST_INTERVAL_MS=100

# Instrument Service Settings
INSTRUMENTS_REFRESH_INTERVAL=21600
INSTRUMENTS_CACHE_TTL=86400
MAX_TRADING_STOCKS=200
OPTION_STRIKE_RANGE=40

# Development/Debug Settings (set to false in production)
ENABLE_TEST_DATA=false
ENABLE_MOCK_UPSTOX=false
ENABLE_WEBSOCKET_DEBUG=false
ENABLE_MARKET_DATA_DEBUG=false



ADMIN_EMAIL=********

# === KEEP ALL YOUR EXISTING .env SETTINGS BELOW ===
# Don't change anything else in your .env file