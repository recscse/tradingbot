# Frontend CI/CD Pipeline for Trading Bot UI (React)
# Compatible with Render fullstack deployment
name: Frontend CI/CD

on:
  push:
    branches: [ "main", "feature-branch" ]
    paths: 
      - 'ui/trading-bot-ui/**'
      - '.github/workflows/node.js.yml'
  pull_request:
    branches: [ "main" ]
    paths:
      - 'ui/trading-bot-ui/**'

permissions:
  contents: read
  pull-requests: write
  checks: write

jobs:
  frontend-test:
    runs-on: ubuntu-latest
    
    defaults:
      run:
        working-directory: ui/trading-bot-ui

    strategy:
      matrix:
        node-version: [20.x]  # Use single version to speed up CI

    steps:
    - name: Checkout repository
      uses: actions/checkout@v4
      
    - name: Check if frontend directory exists
      run: |
        if [ ! -d "../ui/trading-bot-ui" ]; then
          echo "Frontend directory not found, skipping frontend tests"
          exit 0
        fi
      working-directory: .
      
    - name: Use Node.js ${{ matrix.node-version }}
      uses: actions/setup-node@v4
      with:
        node-version: ${{ matrix.node-version }}
        cache: 'npm'
        cache-dependency-path: ui/trading-bot-ui/package-lock.json
        
    - name: Install dependencies
      run: |
        if [ -f "package-lock.json" ]; then
          npm ci
        else
          npm install
        fi
      
    - name: Check for security vulnerabilities
      run: |
        echo "Running security audit..."
        npm audit --audit-level high || echo "Security vulnerabilities found, but continuing build"
      
    - name: Run ESLint (if configured)
      run: |
        if [ -f ".eslintrc.js" ] || [ -f ".eslintrc.json" ] || grep -q "eslint" package.json; then
          echo "Running ESLint..."
          npx eslint src/ --ext .js,.jsx,.ts,.tsx --max-warnings 50 || echo "ESLint warnings found"
        else
          echo "ESLint not configured, skipping"
        fi
        
    - name: Run Prettier check (if configured)
      run: |
        if grep -q "prettier" package.json; then
          echo "Running Prettier check..."
          npx prettier --check src/ || echo "Prettier formatting issues found"
        else
          echo "Prettier not configured, skipping"
        fi
        
    - name: Run tests (if configured)
      run: |
        if grep -q "\"test\":" package.json && [ -d "src/__tests__" ] || [ -f "src/App.test.js" ]; then
          echo "Running tests..."
          npm test -- --coverage --watchAll=false --passWithNoTests
        else
          echo "No tests configured, skipping"
        fi
      env:
        CI: true
        
    - name: Build application for production
      run: |
        echo "🏗️ Building React application..."
        # Use environment variables for Render deployment
        npm run build
      env:
        REACT_APP_API_URL: ${{ secrets.REACT_APP_API_URL || 'http://localhost:8000' }}
        REACT_APP_WS_URL: ${{ secrets.REACT_APP_WS_URL || 'ws://localhost:8000' }}
        GENERATE_SOURCEMAP: false  # Reduce build size
        
    - name: Test build output
      run: |
        echo "📦 Checking build output..."
        if [ -d "build" ]; then
          ls -la build/
          echo "✅ Build completed successfully"
          
          # Check build size
          BUILD_SIZE=$(du -sh build | cut -f1)
          echo "Build size: $BUILD_SIZE"
          
          # Check for critical files
          if [ ! -f "build/index.html" ]; then
            echo "❌ index.html not found in build"
            exit 1
          fi
          
          if [ ! -d "build/static" ]; then
            echo "❌ static directory not found in build"
            exit 1
          fi
          
          echo "✅ Build structure validated"
        else
          echo "❌ Build directory not found"
          exit 1
        fi
        
    - name: Upload build artifacts
      uses: actions/upload-artifact@v3
      with:
        name: frontend-build-${{ matrix.node-version }}
        path: ui/trading-bot-ui/build/
        retention-days: 7

  frontend-security-scan:
    runs-on: ubuntu-latest
    needs: frontend-test
    if: github.event_name == 'pull_request' || github.ref == 'refs/heads/main'
    
    defaults:
      run:
        working-directory: ui/trading-bot-ui
    
    steps:
    - name: Checkout repository
      uses: actions/checkout@v4
      
    - name: Use Node.js 20.x
      uses: actions/setup-node@v4
      with:
        node-version: '20.x'
        cache: 'npm'
        cache-dependency-path: ui/trading-bot-ui/package-lock.json
        
    - name: Install dependencies
      run: npm ci || npm install
      
    - name: Run comprehensive security audit
      run: |
        echo "🔒 Running comprehensive security scan..."
        
        # Create audit report
        npm audit --json --audit-level moderate > npm-audit.json || true
        
        # Check for high/critical vulnerabilities
        HIGH_VULN=$(npm audit --audit-level high --json | jq '.metadata.vulnerabilities.high // 0')
        CRITICAL_VULN=$(npm audit --audit-level critical --json | jq '.metadata.vulnerabilities.critical // 0')
        
        echo "High vulnerabilities: $HIGH_VULN"
        echo "Critical vulnerabilities: $CRITICAL_VULN"
        
        if [ "$CRITICAL_VULN" -gt 0 ]; then
          echo "❌ Critical vulnerabilities found! Manual review required."
          npm audit --audit-level critical
        elif [ "$HIGH_VULN" -gt 5 ]; then
          echo "⚠️ Multiple high vulnerabilities found"
          npm audit --audit-level high
        else
          echo "✅ Security audit passed"
        fi
        
    - name: Scan for hardcoded secrets (if tool available)
      run: |
        # Install secretlint if not available
        if ! command -v secretlint &> /dev/null; then
          echo "Installing secretlint..."
          npm install -g @secretlint/cli @secretlint/secretlint-rule-preset-recommend
        fi
        
        # Scan for secrets
        echo "🔍 Scanning for hardcoded secrets..."
        find src -name "*.js" -o -name "*.jsx" -o -name "*.ts" -o -name "*.tsx" | head -20 | while read file; do
          if grep -l -i -E "(api_key|secret|password|token)" "$file" 2>/dev/null; then
            echo "⚠️ Potential secret found in: $file"
          fi
        done || true

  # Only run performance tests for main branch or PR
  frontend-performance:
    runs-on: ubuntu-latest
    needs: frontend-test
    if: github.ref == 'refs/heads/main' || github.event_name == 'pull_request'
    
    defaults:
      run:
        working-directory: ui/trading-bot-ui
    
    steps:
    - name: Checkout repository
      uses: actions/checkout@v4
      
    - name: Use Node.js 20.x
      uses: actions/setup-node@v4
      with:
        node-version: '20.x'
        cache: 'npm'
        cache-dependency-path: ui/trading-bot-ui/package-lock.json
        
    - name: Install dependencies
      run: npm ci || npm install
      
    - name: Build and analyze bundle (if configured)
      run: |
        echo "📊 Analyzing bundle size..."
        
        # Build the app
        npm run build
        
        # Check if webpack-bundle-analyzer is available
        if grep -q "webpack-bundle-analyzer" package.json; then
          echo "Running bundle analyzer..."
          npm run analyze || echo "Bundle analyzer failed, continuing..."
        else
          echo "Bundle analyzer not configured"
          
          # Basic size analysis
          if [ -d "build/static/js" ]; then
            echo "JavaScript bundle sizes:"
            ls -lah build/static/js/*.js | head -10
            
            # Check for large bundles
            find build/static/js -name "*.js" -size +1M -exec echo "⚠️ Large bundle found: {} $(stat -c%s {})" \;
          fi
          
          if [ -d "build/static/css" ]; then
            echo "CSS bundle sizes:"
            ls -lah build/static/css/*.css | head -10
          fi
        fi

  # Netlify deployment (actual deployment to Netlify)
  netlify-deployment:
    runs-on: ubuntu-latest
    needs: [frontend-test, frontend-security-scan]
    if: github.ref == 'refs/heads/main'
    
    defaults:
      run:
        working-directory: ui/trading-bot-ui
    
    steps:
    - name: Checkout repository
      uses: actions/checkout@v4
      
    - name: Use Node.js 20.x
      uses: actions/setup-node@v4
      with:
        node-version: '20.x'
        cache: 'npm'
        cache-dependency-path: ui/trading-bot-ui/package-lock.json
        
    - name: Install dependencies
      run: npm ci || npm install
      
    - name: Build for production
      run: |
        echo "🏗️ Building for Netlify deployment..."
        npm run build
      env:
        # Use your actual Render backend URL
        REACT_APP_API_URL: ${{ secrets.REACT_APP_API_URL || 'https://your-backend.onrender.com' }}
        REACT_APP_WS_URL: ${{ secrets.REACT_APP_WS_URL || 'wss://your-backend.onrender.com' }}
        REACT_APP_VERSION: ${{ github.sha }}
        GENERATE_SOURCEMAP: false
        
    - name: Deploy to Netlify
      uses: netlify/actions/cli@master
      with:
        args: deploy --prod --dir=ui/trading-bot-ui/build --message="Production deployment from ${{ github.sha }}"
      env:
        NETLIFY_AUTH_TOKEN: ${{ secrets.NETLIFY_AUTH_TOKEN }}
        NETLIFY_SITE_ID: ${{ secrets.NETLIFY_SITE_ID }}
        
    - name: Comment deployment success
      uses: actions/github-script@v6
      if: success()
      with:
        script: |
          const comment = `## Frontend Deployed Successfully!
          
**Netlify Deployment Complete**
- **Environment**: Production
- **Commit**: ${{ github.sha }}
- **Site**: https://${{ secrets.NETLIFY_SITE_ID }}.netlify.app
          
**Live Application**: Check your Netlify dashboard for the live URL
**Performance**: Lighthouse scores available in Netlify dashboard
**Monitoring**: Check frontend performance and errors

*Frontend is now live and connected to Render backend!*`;

          github.rest.repos.createCommitComment({
            owner: context.repo.owner,
            repo: context.repo.repo,
            commit_sha: context.sha,
            body: comment
          });

  # PR preview deployment to Netlify
  netlify-preview:
    runs-on: ubuntu-latest
    needs: [frontend-test]
    if: github.event_name == 'pull_request'
    
    defaults:
      run:
        working-directory: ui/trading-bot-ui
    
    steps:
    - name: Checkout repository
      uses: actions/checkout@v4
      
    - name: Use Node.js 20.x
      uses: actions/setup-node@v4
      with:
        node-version: '20.x'
        cache: 'npm'
        cache-dependency-path: ui/trading-bot-ui/package-lock.json
        
    - name: Install dependencies
      run: npm ci || npm install
      
    - name: Build preview
      run: |
        echo "🏗️ Building preview for PR #${{ github.event.number }}..."
        npm run build
      env:
        # Use staging/preview backend URL for PR builds
        REACT_APP_API_URL: ${{ secrets.REACT_APP_API_URL_STAGING || secrets.REACT_APP_API_URL || 'https://your-backend.onrender.com' }}
        REACT_APP_WS_URL: ${{ secrets.REACT_APP_WS_URL_STAGING || secrets.REACT_APP_WS_URL || 'wss://your-backend.onrender.com' }}
        REACT_APP_VERSION: "pr-${{ github.event.number }}-${{ github.sha }}"
        GENERATE_SOURCEMAP: false
        
    - name: Deploy preview to Netlify
      uses: netlify/actions/cli@master
      id: netlify-deploy
      with:
        args: deploy --dir=ui/trading-bot-ui/build --message="Preview for PR #${{ github.event.number }}"
      env:
        NETLIFY_AUTH_TOKEN: ${{ secrets.NETLIFY_AUTH_TOKEN }}
        NETLIFY_SITE_ID: ${{ secrets.NETLIFY_SITE_ID }}
        
    - name: Comment preview URL
      uses: actions/github-script@v6
      if: success()
      with:
        script: |
          const deployUrl = process.env.NETLIFY_URL || 'Check Netlify dashboard';
          const comment = `## Preview Deployment Ready!
          
**Netlify Preview Deployed**
- **PR**: #${{ github.event.number }}
- **Commit**: ${{ github.sha }}
- **Preview URL**: ${deployUrl}
          
### Testing Checklist
- [ ] Login/Authentication works
- [ ] Trading interface loads
- [ ] WebSocket connections establish
- [ ] Market data displays correctly
- [ ] Responsive design on mobile
          
*Preview will be automatically updated with new commits!*`;

          github.rest.issues.createComment({
            issue_number: context.issue.number,
            owner: context.repo.owner,
            repo: context.repo.repo,
            body: comment
          });

  # Comment on PR with deployment info
  pr-deployment-info:
    runs-on: ubuntu-latest
    needs: [frontend-test, frontend-security-scan]
    if: github.event_name == 'pull_request'
    
    steps:
    - name: Comment on PR
      uses: actions/github-script@v6
      with:
        script: |
          const comment = `## Frontend Deployment Ready
          
**Frontend Build Status**: Passed
**Security Scan**: Completed  
**Bundle Analysis**: Completed

### Deployment Architecture
- **Backend**: Deployed on Render (FastAPI + Python)  
- **Frontend**: Deployed on Netlify (React SPA)
- **Separation**: Clean separation of concerns with API + UI

### Next Steps
1. Merge this PR to trigger automatic deployments
2. Backend will deploy to Render automatically
3. Frontend will deploy to Netlify automatically
4. Monitor both deployments in respective dashboards

*This PR is ready for review and deployment!*`;

          github.rest.issues.createComment({
            issue_number: context.issue.number,
            owner: context.repo.owner,
            repo: context.repo.repo,
            body: comment
          });
