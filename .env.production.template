# Production Environment Configuration Template
# Copy this file to .env.production and fill in the values

# ================================
# APPLICATION SETTINGS
# ================================
ENVIRONMENT=production
APP_NAME=TradingBot
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# ================================
# DATABASE CONFIGURATION
# ================================
DATABASE_URL=postgresql://username:password@host:port/database_name
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# ================================
# REDIS CONFIGURATION
# ================================
REDIS_ENABLED=true
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your-redis-password
REDIS_SSL=true
REDIS_CONNECTION_POOL_SIZE=50

# ================================
# SECURITY SETTINGS
# ================================
JWT_SECRET_KEY=your-super-secure-jwt-secret-key-at-least-32-characters
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
SECRET_KEY=your-django-style-secret-key-for-general-encryption

# ================================
# BROKER API CREDENTIALS
# ================================
# Upstox Configuration
UPSTOX_API_KEY=your-upstox-api-key
UPSTOX_API_SECRET=your-upstox-api-secret
UPSTOX_REDIRECT_URI=https://yourdomain.com/api/v1/auth/upstox/callback
UPSTOX_MOBILE=your-mobile-number-for-automation
UPSTOX_PIN=your-6-digit-pin
UPSTOX_TOTP_KEY=your-totp-secret-key

# Angel One Configuration
ANGEL_ONE_API_KEY=your-angel-one-api-key
ANGEL_ONE_CLIENT_ID=your-angel-one-client-id
ANGEL_ONE_PASSWORD=your-angel-one-password
ANGEL_ONE_TOTP_KEY=your-angel-one-totp-key

# Dhan Configuration
DHAN_CLIENT_ID=your-dhan-client-id
DHAN_ACCESS_TOKEN=your-dhan-access-token

# Zerodha Configuration
ZERODHA_API_KEY=your-zerodha-api-key
ZERODHA_API_SECRET=your-zerodha-api-secret
ZERODHA_USER_ID=your-zerodha-user-id
ZERODHA_PASSWORD=your-zerodha-password
ZERODHA_PIN=your-zerodha-pin

# Fyers Configuration
FYERS_APP_ID=your-fyers-app-id
FYERS_SECRET_KEY=your-fyers-secret-key
FYERS_REDIRECT_URI=https://yourdomain.com/api/v1/auth/fyers/callback

# ================================
# EMAIL CONFIGURATION
# ================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
EMAIL_FROM=your-email@gmail.com
EMAIL_FROM_NAME=Trading Bot

# Error notification emails
ERROR_EMAIL_TO=admin@yourdomain.com
ERROR_EMAIL_FROM=errors@yourdomain.com

# ================================
# MONITORING & OBSERVABILITY
# ================================
# Prometheus metrics
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Grafana configuration
GRAFANA_PASSWORD=your-secure-grafana-password

# Application monitoring
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
DATADOG_API_KEY=your-datadog-api-key
NEWRELIC_LICENSE_KEY=your-newrelic-license-key

# ================================
# BACKUP CONFIGURATION
# ================================
# AWS S3 for backups
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
BACKUP_S3_BUCKET=your-backup-bucket-name

# Backup settings
BACKUP_RETENTION_DAYS=30
BACKUP_FREQUENCY_HOURS=6
LOCAL_BACKUP_DIR=./backups
ENCRYPT_BACKUPS=true
BACKUP_ENCRYPTION_KEY=your-backup-encryption-passphrase

# ================================
# WEBSOCKET CONFIGURATION
# ================================
WEBSOCKET_MAX_CONNECTIONS=1000
WEBSOCKET_HEARTBEAT_INTERVAL=30
WEBSOCKET_TIMEOUT=60
WEBSOCKET_BUFFER_SIZE=65536

# ================================
# TRADING CONFIGURATION
# ================================
# Risk management
MAX_POSITION_SIZE=100000
MAX_DAILY_LOSS=50000
MAX_ORDER_VALUE=1000000
STOP_LOSS_PERCENTAGE=5.0
TAKE_PROFIT_PERCENTAGE=10.0

# Market data
MARKET_DATA_REFRESH_INTERVAL=1000
PRICE_ALERT_THRESHOLD=2.0
VOLUME_ALERT_MULTIPLIER=3.0

# ================================
# COMPLIANCE SETTINGS
# ================================
COMPLIANCE_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=2555  # 7 years as per SEBI requirements
REGULATORY_REPORTING=true
POSITION_LIMIT_ALERTS=true

# ================================
# PERFORMANCE SETTINGS
# ================================
# Memory limits (for Render deployment)
MAX_MEMORY_MB=450
WORKER_TIMEOUT=120
KEEPALIVE_TIMEOUT=5
MAX_REQUESTS=1000
MAX_REQUESTS_JITTER=50

# Connection pools
DB_POOL_SIZE=10
REDIS_POOL_SIZE=20
HTTP_POOL_SIZE=100

# ================================
# PLAYWRIGHT AUTOMATION
# ================================
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000
PLAYWRIGHT_BROWSER_ARGS=--no-sandbox,--disable-dev-shm-usage,--disable-gpu

# ================================
# RATE LIMITING
# ================================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=100
RATE_LIMIT_ENABLED=true

# ================================
# SSL/TLS CONFIGURATION
# ================================
SSL_REDIRECT=true
SECURE_COOKIES=true
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true

# ================================
# LOGGING CONFIGURATION
# ================================
LOG_FORMAT=json
LOG_ROTATION=midnight
LOG_BACKUP_COUNT=30
LOG_MAX_BYTES=100MB

# Specific log levels
DB_LOG_LEVEL=WARNING
BROKER_LOG_LEVEL=INFO
TRADING_LOG_LEVEL=DEBUG
WEBSOCKET_LOG_LEVEL=INFO

# ================================
# FEATURE FLAGS
# ================================
ENABLE_PAPER_TRADING=true
ENABLE_AI_TRADING=true
ENABLE_BACKTESTING=true
ENABLE_OPTIONS_TRADING=true
ENABLE_MARGIN_TRADING=false
ENABLE_CRYPTO_TRADING=false

# ================================
# THIRD-PARTY INTEGRATIONS
# ================================
# Google OAuth
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Telegram Bot (for alerts)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# WhatsApp Business API
WHATSAPP_BUSINESS_TOKEN=your-whatsapp-business-token
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id

# ================================
# DEPLOYMENT SPECIFIC
# ================================
# Render.com specific
RENDER_EXTERNAL_URL=https://your-app.onrender.com
RENDER_INTERNAL_HOSTNAME=your-app
RENDER_SERVICE_ID=your-render-service-id

# Netlify specific (for frontend)
REACT_APP_API_URL=https://your-api.onrender.com
REACT_APP_WS_URL=wss://your-api.onrender.com
REACT_APP_SENTRY_DSN=your-frontend-sentry-dsn
REACT_APP_GA_TRACKING_ID=your-google-analytics-id

# ================================
# HEALTH CHECK CONFIGURATION
# ================================
HEALTH_CHECK_TIMEOUT=30
HEALTH_CHECK_INTERVAL=60
ENABLE_DEEP_HEALTH_CHECKS=true

# ================================
# CACHE CONFIGURATION
# ================================
CACHE_TTL_SECONDS=300
CACHE_MAX_SIZE=1000
ENABLE_QUERY_CACHE=true
ENABLE_API_RESPONSE_CACHE=true